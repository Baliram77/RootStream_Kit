## Frontend public environment variables (Next.js)
## Copy to `.env.local` and fill in real values.
##
## NOTE: Variables prefixed with NEXT_PUBLIC_ are embedded into the browser bundle.

# Rootstream contract address on Rootstock Testnet (chain id 31)
NEXT_PUBLIC_ROOTSTREAM_ADDRESS=0x0000000000000000000000000000000000000000

# Block number where the contract was deployed (used as a fromBlock for log scans)
NEXT_PUBLIC_ROOTSTREAM_DEPLOY_BLOCK=0

# JSON-RPC URL (must support eth_getLogs for History tables)
NEXT_PUBLIC_RPC_URL=https://public-node.testnet.rsk.co

# Envio GraphQL endpoint as reachable by the browser
NEXT_PUBLIC_ENVIO_GRAPHQL_URL=http://127.0.0.1:8080/v1/graphql

# Optional lookback window for PaymentExecuted log scans
NEXT_PUBLIC_PAYMENT_LOG_LOOKBACK_BLOCKS=250000

# Optional chain id (Rootstock testnet)
NEXT_PUBLIC_CHAIN_ID=31

# Optional (enables WalletConnect connector)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

